# ──────────────────────────────────────────────────────────────
# ADWF Backend — Environment Variables
# Copy this file to .env and fill in the required values.
# ──────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adwf:adwf_dev_password@localhost:5432/adwf
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Qdrant ──────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # Leave empty for local Qdrant

# ── LLM (Groq for free tier) ────────────────────────────────────
OPENAI_API_KEY=gsk_...                  # Required — get from console.groq.com
OPENAI_MODEL=llama3-70b-8192
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Application ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-32-char-random-string!!
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
DEBUG=false

# ── Pipeline ────────────────────────────────────────────────────
MAX_QA_ITERATIONS=3
DEFAULT_TARGET_PLATFORM=web
ARTIFACT_STORAGE_PATH=./artifacts

# ── Celery ──────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Optional External APIs (Research Agent) ──────────────────────
SERP_API_KEY=                           # SERP API for web search
CRUNCHBASE_API_KEY=                     # Crunchbase for market data
